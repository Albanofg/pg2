# ─────────────────────────────────────────────────────────────
# Patent Geyser 2.0 — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# ─────────────────────────────────────────────────────────────

# Neon serverless Postgres connection string (Neon dashboard -> Connection Details).
# App tables live in the `patentgeyser2o` schema; other schemas are untouched.
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# Vercel Blob storage (Vercel dashboard -> Storage -> Blob -> .env.local)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# OpenAI — structured agents use the gpt-4o family
OPENAI_API_KEY="sk-xxx"

# Google Gemini — deep cross-verification runs on gemini-2.5-pro, reached via
# Google's OpenAI-compatible endpoint (no extra provider package needed).
GEMINI_API_KEY="AQ.xxx"

# RFC 3161 timestamp authority (free public endpoint, no account needed)
TSA_URL="http://timestamp.digicert.com"

# Module 3 (Landscape) — prior-art search. URL of the n8n workflow webhook the
# Landscape stage POSTs each idea to ({ id, title, statement, context }) and
# which returns the matching patents/papers. See lib/modules/landscape/search.n8n.ts.
LANDSCAPE_SEARCH_URL="https://your-n8n-host/webhook/prior-art-search"
